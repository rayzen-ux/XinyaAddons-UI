    <string name="dialog_uv_stage1_title">Peringatan Ketidakstabilan</string>
    <string name="dialog_uv_stage1_msg">Offset lebih rendah dari -50 mV menimbulkan risiko reboot acak dan freeze yang signifikan.</string>
    
    <string name="dialog_uv_stage2_title">RISIKO KERUSAKAN PERANGKAT KERAS</string>
    <string name="dialog_uv_stage2_msg">Anda menerapkan nilai ekstrem.\n\nIni dapat menyebabkan kerusakan perangkat keras permanen, kerusakan sistem file, atau bootloop.\n\nPENGEMBANG TIDAK BERTANGGUNG JAWAB atas kerusakan apa pun pada perangkat Anda.</string>
