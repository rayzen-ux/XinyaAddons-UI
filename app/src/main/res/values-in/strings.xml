    <string name="dialog_uv_advanced_title">Aktifkan Mode Lanjutan?</string>
    <string name="dialog_uv_advanced_msg">Anda akan membuka rentang voltase yang tidak aman.\n\nMenerapkan nilai yang salah dapat menyebabkan bootloop, kehilangan data, atau ketidakstabilan perangkat keras.\n\nPengembang TIDAK bertanggung jawab atas kerusakan apa pun yang disebabkan oleh penggunaan fitur ini.</string>
    <string name="btn_accept_risk">Saya Terima Risikonya</string>
    
    <string name="dialog_uv_stage1_title">Peringatan Ketidakstabilan</string>
    <string name="dialog_uv_stage1_msg">Offset lebih rendah dari -50 mV menimbulkan risiko besar reboot acak dan macet.</string>
    <string name="btn_understand">Saya Mengerti</string>
    
    <string name="dialog_uv_stage2_title">RISIKO KERUSAKAN HARDWARE</string>
    <string name="dialog_uv_stage2_msg">Anda menerapkan nilai ekstrem.\n\nIni dapat menyebabkan kerusakan perangkat keras permanen, korupsi sistem file, atau bootloop.\n\nPENGEMBANG TIDAK BERTANGGUNG JAWAB atas kerusakan apa pun pada perangkat Anda.</string>
    <string name="btn_accept_responsibility">Saya Tanggung Jawab</string>
    
    <string name="dialog_uv_info_title">Tentang Undervolting</string>
    <string name="dialog_uv_info_1">Undervolting mengurangi voltase yang dipasok ke CPU/GPU, mengurangi panas dan konsumsi daya.</string>
    <string name="dialog_uv_info_2">Offset diterapkan relatif terhadap tabel voltase pabrik. Nilai negatif berlebihan menyebabkan ketidakstabilan.</string>
    <string name="dialog_uv_info_3">Rekomendasi: -11mV untuk kluster CPU.</string>
    
