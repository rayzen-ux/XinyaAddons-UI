    <string name="about_title">Tentang</string>
    <string name="about_app_desc">Xia\'s Addons adalah toolkit canggih yang dirancang untuk membuka potensi penuh perangkat Anda. Aplikasi ini menjembatani kesenjangan antara modifikasi sistem yang kompleks dan kontrol yang ramah pengguna, menawarkan manajemen sumber daya perangkat keras yang terperinci.</string>
    
    <string name="about_features_header">FITUR UTAMA</string>
    <string name="about_feat_perf">Pemrofilan Performa</string>
    <string name="about_feat_perf_desc">Penskalaan frekuensi CPU/GPU tingkat lanjut dan manajemen governor.</string>
    <string name="about_feat_identity">Spoofing Identitas</string>
    <string name="about_feat_identity_desc">Bypass pemeriksaan Play Integrity dan buka fitur khusus aplikasi.</string>
    <string name="about_feat_power">Manajemen Daya</string>
    <string name="about_feat_power_desc">Bypass kontrol keamanan pengisian daya dan termal.</string>

    <string name="about_safety_header">KEAMANAN &amp; BAWAAN</string>
    <string name="about_safety_title">Mengapa Bawaan Penting</string>
    <string name="about_safety_desc">Konfigurasi bawaan disetel untuk stabilitas dan keamanan. Modul lanjutan seperti Undervolting dan Override Termal sangat kuat tetapi berisiko. Kami menyarankan untuk tetap menggunakan profil "Seimbang" kecuali Anda memahami implikasi perangkat kerasnya.</string>

