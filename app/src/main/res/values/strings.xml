    <string name="io_scheduler_title">I/O Scheduler</string>
    <string name="io_warning_msg">Changing the I/O Scheduler may impact system stability or data integrity. If you notice lags or freezes, revert to Default.</string>
    <string name="io_guide_title">I/O Scheduler Guide</string>
    <string name="io_guide_desc">The I/O Scheduler decides the order in which storage read/write requests are processed. Choosing the right one can improve responsiveness or battery life.</string>
    <string name="io_common_types">Common Types:</string>
    <string name="io_type_noop">Noop / None</string>
    <string name="io_desc_noop">Basic FIFO. Best for modern Flash Storage (UFS/NVMe) as the hardware handles sorting.</string>
    <string name="io_type_mq">MQ-Deadline</string>
    <string name="io_desc_mq">Prioritizes read requests to prevent lag. Good general purpose.</string>
    <string name="io_type_bfq">BFQ</string>
    <string name="io_desc_bfq">Complex scheduler for HDDs/slow storage. High overhead but good fairness.</string>
    <string name="io_guide_footer">Recommendation: If unsure, select \'none\' or \'mq-deadline\' (Default).</string>
    <string name="io_sched_recommendation">Recommended: \'none\' or \'mq-deadline\' for modern storage.</string>
