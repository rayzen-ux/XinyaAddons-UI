    <string name="dialog_uv_info_title">About Undervolting</string>
    <string name="dialog_uv_info_1">Undervolting reduces the voltage supplied to the CPU/GPU, reducing heat and power consumption.</string>
    <string name="dialog_uv_info_2">Offsets are applied relative to the factory voltage table. Excessive negative values cause instability.</string>
    <string name="dialog_uv_info_3">Recommended: -11mV for CPU clusters.</string>
    
